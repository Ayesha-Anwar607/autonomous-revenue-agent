# .dockerignore — Exclude files from the Docker build context
# This keeps the image lean and prevents secrets from leaking into the container

# ── Secrets (NEVER ship these) ───────────────────────────────────
.env
.env.*
*.pem
*.key

# ── Git & CI ─────────────────────────────────────────────────────
.git
.github
.gitignore
.pre-commit-config.yaml

# ── Python runtime artifacts ─────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Test & dev tooling ───────────────────────────────────────────
tests/
.pytest_cache/
.coverage
htmlcov/
*.log

# ── Virtual environments ─────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / OS files ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docs & non-runtime files ─────────────────────────────────────
*.md
docs/
SECURITY.md
